# Gold DW (medallion_db) — read-only, regenerable from ETL
GOLD_DB_HOST=localhost
GOLD_DB_PORT=5432
GOLD_DB_NAME=medallion_db
GOLD_DB_USER=
GOLD_DB_PASSWORD=

# App DB (sellers_app_db) — read-write, backup-critical (auth + operations)
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_NAME=sellers_app_db
APP_DB_USER=
APP_DB_PASSWORD=

# JWT (dev default is insecure, set a real value for staging/production)
# JWT_SECRET_KEY=
ENVIRONMENT=development

# Weather API (OpenWeatherMap — free tier 1000 calls/day)
# OPENWEATHER_API_KEY=
