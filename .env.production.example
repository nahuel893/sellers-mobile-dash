# ─────────────────────────────────────────────────────────────────────────────
# .env.production — Seller Mobile Dashboard
# Copy to .env.production, fill values, DO NOT commit the real file.
# ─────────────────────────────────────────────────────────────────────────────

# ── App environment ───────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_use_a_long_random_secret

# Token expiry (optional — defaults shown)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# bcrypt work factor (12 is safe; increase slows logins but hardens brute force)
BCRYPT_ROUNDS=12

# ── PostgreSQL (external Gold DW — NOT in docker-compose) ─────────────────────
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=gold_db
DB_USER=your_db_user
DB_PASSWORD=CHANGE_ME_db_password

# ── Auth DB (seller_dashboard_db — separate from Gold DW) ────────────────────
# Contains auth schema: users, roles, refresh_tokens, user_sucursales.
# If AUTH_DB_HOST/USER/PASSWORD are not set, they fall back to DB_* above.
# Only AUTH_DB_NAME is required when both DBs live on the same server.
AUTH_DB_HOST=your-postgres-host
AUTH_DB_PORT=5432
AUTH_DB_NAME=seller_dashboard_db
AUTH_DB_USER=your_db_user
AUTH_DB_PASSWORD=CHANGE_ME_db_password
