# ─────────────────────────────────────────────────────────────────────────────
# .env.production — Seller Mobile Dashboard
# Copy to .env.production, fill values, DO NOT commit the real file.
# ─────────────────────────────────────────────────────────────────────────────

# ── App environment ───────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_use_a_long_random_secret

# Token expiry (optional — defaults shown)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# bcrypt work factor (12 is safe; increase slows logins but hardens brute force)
BCRYPT_ROUNDS=12

# ── Gold DW (medallion_db — read-only, owned by ETL/Gold team) ───────────────
GOLD_DB_HOST=your-postgres-host
GOLD_DB_PORT=5432
GOLD_DB_NAME=medallion_db
GOLD_DB_USER=your_gold_db_user
GOLD_DB_PASSWORD=CHANGE_ME_gold_db_password

# ── App DB (sellers_app_db — read-write, backup-critical) ────────────────────
# Contains: auth.* (users, roles, tokens) + operations.* (visitas, etc).
# Run migrations before first start: psql -d sellers_app_db -f migrations/001_auth_schema.sql
APP_DB_HOST=your-postgres-host
APP_DB_PORT=5432
APP_DB_NAME=sellers_app_db
APP_DB_USER=your_app_db_user
APP_DB_PASSWORD=CHANGE_ME_app_db_password
